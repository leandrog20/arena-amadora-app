# Copie este arquivo para .env e preencha os valores

# Porta (Render/Railway definem automaticamente)
PORT=3000

# Segredo do JWT — TROQUE para algo aleatório em produção!
JWT_SECRET=mude_isso_para_uma_string_aleatoria_segura

# Senha do admin (login: admin / senha abaixo)
ADMIN_PASSWORD=admin123

# Origens permitidas no CORS (separe por vírgula)
ALLOWED_ORIGINS=http://localhost:3000,https://arena-amadora-app-production.up.railway.app

# Caminho do banco SQLite (opcional, padrão: ./db/arena.db)
# DB_PATH=/tmp/arena-db

NODE_ENV=development
