# ──────────────────────────────────────────────
# Arena Amadora — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ──────────────────────────────────────────────

# Porta do servidor (Render/Railway definem automaticamente)
PORT=3000

# Ambiente: development | production
NODE_ENV=development

# ── JWT (OBRIGATÓRIO em produção) ──────────────
# Gere um secret seguro:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=TROQUE_ISSO_PARA_UMA_STRING_ALEATORIA_MUITO_LONGA_EM_PRODUCAO

# ── Admin ──────────────────────────────────────
# MODO DESENVOLVIMENTO: senha em texto plano (apenas dev)
ADMIN_PASSWORD=admin123

# MODO PRODUÇÃO: hash bcrypt da senha (mais seguro)
# Para gerar o hash: node -e "require('bcryptjs').hash('SUA_SENHA',12).then(console.log)"
# ADMIN_PASSWORD_HASH=$2a$12$SEU_HASH_AQUI

# ── CORS ───────────────────────────────────────
# Lista de origens permitidas, separadas por vírgula
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://arena-amadora-app-production.up.railway.app
# Em produção: ALLOWED_ORIGINS=https://arena-amadora.com.br

# ── Banco de dados ─────────────────────────────
# Caminho do SQLite (Railway: ./db | Render: /tmp)
# DB_PATH=/tmp/arena-db
